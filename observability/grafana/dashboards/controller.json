{
  "annotations": { "list": [] },
  "description": "Closed-loop controller recommendations and quality metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "content": "## Closed-Loop Controller\nMonitors routing recommendations based on shadow mode quality metrics. Compares local (gemma3:4b, mistral) vs cloud (claude-sonnet-4, gemini-2.0-flash).",
        "mode": "markdown"
      },
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.85 }] },
          "unit": "percentunit", "min": 0, "max": 1
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 2 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [{ "expr": "sentinel_shadow_similarity_score_sum / sentinel_shadow_similarity_score_count", "legendFormat": "Avg Similarity", "refId": "A" }],
      "title": "Similarity Score (Local vs Cloud)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 2 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "sentinel_shadow_cost_savings_potential_usd_total", "legendFormat": "Total Savings", "refId": "A" }],
      "title": "Cost Savings (Local Routing)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "none"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 2 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "sentinel_shadow_requests_total{status=\"success\"}", "legendFormat": "Shadow Comparisons", "refId": "A" }],
      "title": "Shadow Comparisons",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "none"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 2 },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [{ "expr": "sum(sentinel_requests_total{route=\"cloud\",status=\"success\"})", "legendFormat": "Cloud Requests", "refId": "A" }],
      "title": "Cloud Requests (Tier 0-1)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth",
            "lineWidth": 2, "showPoints": "auto", "spanNulls": false,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0.85 }] },
          "unit": "percentunit", "min": 0, "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [{ "expr": "rate(sentinel_shadow_similarity_score_sum[5m]) / rate(sentinel_shadow_similarity_score_count[5m])", "legendFormat": "Similarity (5m avg)", "refId": "A" }],
      "title": "Similarity Over Time (Local vs Cloud Quality)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": true, "axisLabel": "seconds",
            "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth",
            "lineWidth": 2, "showPoints": "auto", "spanNulls": false
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(sentinel_shadow_latency_diff_seconds_bucket[5m]))", "legendFormat": "p50 Latency Diff", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(sentinel_shadow_latency_diff_seconds_bucket[5m]))", "legendFormat": "p95 Latency Diff", "refId": "B" }
      ],
      "title": "Latency Diff (Local - Cloud)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth",
            "lineWidth": 2, "showPoints": "auto", "spanNulls": false
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [{ "expr": "sentinel_shadow_cost_savings_potential_usd_total", "legendFormat": "Cumulative Savings", "refId": "A" }],
      "title": "Cumulative Cost Savings",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*gemma3.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*mistral.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*claude.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": ".*gemini.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "local" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "cloud" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 9,
      "options": {
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "pieType": "pie",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "sum(sentinel_requests_total{route=\"cloud\"})", "legendFormat": "cloud", "refId": "A" },
        { "expr": "sum(sentinel_requests_total{route=\"local\"})", "legendFormat": "local", "refId": "B" }
      ],
      "title": "Route Distribution",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth",
            "lineWidth": 2, "showPoints": "auto", "spanNulls": false
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        { "expr": "rate(sentinel_shadow_requests_total{status=\"success\"}[1m])", "legendFormat": "Shadow Comparisons/sec", "refId": "A" },
        { "expr": "rate(sentinel_requests_total{route=\"cloud\"}[1m])", "legendFormat": "Cloud Requests/sec", "refId": "B" }
      ],
      "title": "Shadow vs Cloud Request Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["sentinel", "controller", "shadow"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Data Source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "title": "Inference Sentinel - Controller",
  "uid": "sentinel-controller",
  "version": 1
}
