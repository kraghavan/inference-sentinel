  "panels": [
    {
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "content": "# Closed-Loop Controller Dashboard\n\nMonitors routing recommendations based on shadow mode quality metrics. Controller runs in **observe** mode - it logs recommendations but does not auto-apply changes.",
        "mode": "markdown"
      },
      "title": "",
      "type": "text"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "route_to_local": { "color": "green", "index": 0, "text": "Route to Local" } }, "type": "value" },
            { "options": { "keep_on_cloud": { "color": "blue", "index": 1, "text": "Keep on Cloud" } }, "type": "value" },
            { "options": { "drift_alert": { "color": "red", "index": 2, "text": "Drift Alert" } }, "type": "value" },
            { "options": { "insufficient_data": { "color": "yellow", "index": 3, "text": "Insufficient Data" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 3 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "{job=\"sentinel\"} |= `controller_recommendation` | json | tier=`0`",
          "legendFormat": "Tier 0",
          "refId": "A"
